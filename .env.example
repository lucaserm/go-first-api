# Database (used by goose for migrations and by the app at runtime)
GOOSE_DBSTRING="host=localhost user=postgres password=postgres dbname=ecom sslmode=disable"
GOOSE_DRIVER=postgres
GOOSE_MIGRATION_DIR=./internal/adapters/postgresql/migrations

# Auth — REQUIRED, the server refuses to boot without JWT_SECRET.
# Generate one with: openssl rand -hex 32
JWT_SECRET=
JWT_EXP=604800 # token lifetime in seconds (default: 7 days)

# Stripe (payments + tax) — required once the checkout phase lands
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# EasyPost (live shipping rates) — required once the shipping phase lands
EASYPOST_API_KEY=
